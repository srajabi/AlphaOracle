################################################################################
# LLM API Keys
################################################################################
# ⚠️  PLACEHOLDER - Replace in .env with your actual Gemini API key
GEMINI_API_KEY="your_gemini_api_key_here"

# ⚠️  PLACEHOLDER - Replace in .env with your actual OpenAI API key
OPENAI_API_KEY="your_openai_api_key_here"

# ⚠️  PLACEHOLDER - Replace in .env with your actual Anthropic API key
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# ⚠️  PLACEHOLDER - Replace in .env with your actual DeepSeek API key
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

################################################################################
# LLM Model Routing
################################################################################
# Local defaults use deepseek/deepseek-reasoner when unset
# For multi-model role runs, use comma-separated lists
RISK_MODELS="deepseek/deepseek-reasoner,gemini/gemini-2.5-flash"
TECH_MODELS="deepseek/deepseek-reasoner,gemini/gemini-2.5-flash"
MACRO_MODELS="deepseek/deepseek-reasoner,gemini/gemini-2.5-flash"
PM_MODEL="deepseek/deepseek-reasoner"

################################################################################
# Alpaca Trading - Development/Testing Account
################################################################################
# Used for: local testing, manual workflow triggers, development
# This account will have random/test trades - that's OK!
# ⚠️  PLACEHOLDER - Replace in .env with your actual Alpaca dev API key
ALPACA_DEV_API_KEY="PKxxxxxxxxxxxxxxxxxxxxx"
# ⚠️  PLACEHOLDER - Replace in .env with your actual Alpaca dev secret key
ALPACA_DEV_SECRET_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

################################################################################
# Alpaca Trading - Production Accounts
################################################################################
# Used for: scheduled workflow runs only (10am & 3:30pm ET weekdays)
# Each account runs a specific strategy

