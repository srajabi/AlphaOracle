# Copy this file to .env and fill in your actual keys.
# DO NOT COMMIT .env TO GITHUB.

# LLM Providers
GEMINI_API_KEY="your_gemini_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"
ANTHROPIC_API_KEY="your_anthropic_api_key_here"
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# LLM model routing
# Local defaults now use deepseek/deepseek-reasoner when these are unset.
# For multi-model role runs, set comma-separated lists.
RISK_MODELS="deepseek/deepseek-reasoner,gemini/gemini-2.5-flash"
TECH_MODELS="deepseek/deepseek-reasoner,gemini/gemini-2.5-flash"
MACRO_MODELS="deepseek/deepseek-reasoner,gemini/gemini-2.5-flash"
PM_MODEL="deepseek/deepseek-reasoner"

# Trading
ALPACA_API_KEY="your_alpaca_key_here"
ALPACA_SECRET_KEY="your_alpaca_secret_here"
