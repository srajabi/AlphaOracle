---
import Layout from '../layouts/Layout.astro';
import '../styles/backtests.css';
import fs from 'node:fs/promises';
import path from 'node:path';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// Load comprehensive backtest results
let resultsData: any = {};
try {
  const content = await fs.readFile(path.resolve('./public/data/backtest_results_comprehensive.json'), 'utf-8');
  resultsData = JSON.parse(content);
} catch (e) {
  console.error('Failed to load backtest results:', e);
}

// Load leverage comparison results
let leverageData: any = {};
try {
  const content = await fs.readFile(path.resolve('./public/data/backtest_results_leverage_comparison.json'), 'utf-8');
  leverageData = JSON.parse(content);
} catch (e) {
  console.error('Failed to load leverage comparison results:', e);
}

const fullSampleResults = resultsData?.summary_by_period
  ?.filter((r: any) => r.period === 'full_sample')
  ?.sort((a: any, b: any) => b.total_return - a.total_return) || [];

const leverageResults = leverageData?.summary || [];
const findResult = (name: string) => leverageResults.find((r: any) => r.strategy === name);

const formatPercent = (val: number) => (val * 100).toFixed(1) + '%';
const formatSharpe = (val: number) => val.toFixed(2);
const formatDollar = (val: number) => '$' + (10000 * (1 + val)).toLocaleString(undefined, { maximumFractionDigits: 0 });
---

<Layout title="Backtest Results - AlphaOracle">
  <main>
  <div class="backtests-container">
    <header class="backtests-header">
      <h1>Strategy Backtest Results</h1>
      <p class="subtitle">33-year comprehensive analysis (1993-2026) with zero-fee assumptions</p>
      <div class="validation-badge">⚠️ Regime-Dependent: Excelled in 2011-2026 Bull Market</div>
    </header>

    <!-- Executive Summary -->
    <section class="executive-summary">
      <h2>🎯 Executive Summary</h2>
      <div class="summary-cards">
        <div class="summary-card highlight">
          <h3>🚀 Best Absolute Returns</h3>
          <div class="stat">reddit_200sma_tqqq</div>
          <div class="value">+26,860%</div>
          <div class="detail">$10k → $2.7M with only 23 trades (0.7/year)</div>
        </div>
        <div class="summary-card highlight">
          <h3>⚖️ Best Risk-Adjusted</h3>
          <div class="stat">regime_defensive</div>
          <div class="value">Sharpe 0.93</div>
          <div class="detail">+1,106% return with -26% max drawdown</div>
        </div>
        <div class="summary-card highlight">
          <h3>💰 Best Tax Efficiency</h3>
          <div class="stat">reddit_200sma_spy</div>
          <div class="value">17 trades in 33 years</div>
          <div class="detail">+8,709% with minimal tax drag</div>
        </div>
      </div>

      <div class="key-insights">
        <h3>Key Findings</h3>
        <ul>
          <li><strong>Reddit strategies dominate</strong> in absolute returns (3-27x advantage) with ultra-low turnover</li>
          <li><strong>Tolerance bands reduce trades 66%</strong> (714 → 243) but lower returns 28%</li>
          <li><strong>Tax efficiency is critical:</strong> High-turnover strategies lose ~75% of returns in taxable accounts</li>
          <li><strong>⚠️ Regime-dependent performance:</strong> All strategies excelled in 2011-2026 bull market but struggled 1993-2010</li>
          <li><strong>reddit_200sma_tqqq LOST MONEY 1993-2010</strong> (-0.8% CAGR) but dominated 2011-2026 (+35.8% CAGR)</li>
          <li><strong>ETF liquidity matters:</strong> Stick to TQQQ/UPRO/TMF for live trading</li>
        </ul>
      </div>
    </section>

    <!-- Full Results Table -->
    <section class="results-section">
      <h2>📊 Full 33-Year Performance</h2>
      <p class="section-description">All strategies tested with zero transaction costs (realistic for modern brokers)</p>

      <div class="results-table-wrapper">
        <table class="results-table">
          <thead>
            <tr>
              <th>Strategy</th>
              <th>Total Return</th>
              <th>$10k →</th>
              <th>CAGR</th>
              <th>Sharpe</th>
              <th>Max DD</th>
              <th>Trades</th>
              <th>Trades/Year</th>
            </tr>
          </thead>
          <tbody>
            {fullSampleResults.map((result: any) => {
              const isReddit = result.strategy.includes('reddit');
              const isBestReturn = result === fullSampleResults[0];
              const isBestSharpe = fullSampleResults.every((r: any) => result.sharpe >= r.sharpe);
              const tradesPerYear = (result.trades / 33).toFixed(1);

              return (
                <tr class={isReddit ? 'reddit-strategy' : isBestSharpe ? 'best-sharpe' : ''}>
                  <td class="strategy-name">
                    {result.strategy.replace(/_/g, ' ')}
                    {isBestReturn && <span class="badge best-return">Highest Return</span>}
                    {isBestSharpe && <span class="badge best-sharpe">Best Sharpe</span>}
                    {isReddit && <span class="badge reddit">Reddit Strategy</span>}
                  </td>
                  <td class={result.total_return > 0 ? 'positive' : 'negative'}>
                    {formatPercent(result.total_return)}
                  </td>
                  <td class="dollar-value">{formatDollar(result.total_return)}</td>
                  <td class={result.annualized_return > 0 ? 'positive' : 'negative'}>
                    {formatPercent(result.annualized_return)}
                  </td>
                  <td class={result.sharpe > 0.5 ? 'positive' : result.sharpe > 0 ? 'neutral' : 'negative'}>
                    {formatSharpe(result.sharpe)}
                  </td>
                  <td class="negative">{formatPercent(result.max_drawdown)}</td>
                  <td>{Math.round(result.trades)}</td>
                  <td class={parseFloat(tradesPerYear) < 2 ? 'positive' : parseFloat(tradesPerYear) < 10 ? 'neutral' : 'warning'}>
                    {tradesPerYear}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Leverage Comparison -->
    <section class="leverage-comparison">
      <h2>⚖️ Leverage Comparison: Timing vs Buy & Hold</h2>
      <div class="correction-notice">
        <strong>⚠️ APPLES-TO-APPLES FIX:</strong> Previously compared different leverage levels. Now properly comparing timing strategies vs buy-and-hold at the SAME leverage level.
      </div>

      <div class="comparison-grid">
        <!-- SPY 3x Comparison -->
        <div class="comparison-card highlight">
          <h3>SPY 3x: Timing vs Buy & Hold</h3>
