              <div>Regime 2x</div>
            </div>
            <div class="comparison-row">
              <div>33-Year Return</div>
              <div class="positive">+26,860%</div>
              <div class="positive">+9,785%</div>
            </div>
            <div class="comparison-row">
              <div>Trades (33 years)</div>
              <div class="positive">23 (0.7/year)</div>
              <div class="warning">714 (22/year)</div>
