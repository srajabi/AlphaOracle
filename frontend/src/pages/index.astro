---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs/promises';
import path from 'node:path';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

let contextData = { regime: 'Unknown', date: '' };
try {
  const content = await fs.readFile(path.resolve('./public/data/market_context.json'), 'utf-8');
  const parsed = JSON.parse(content);
  contextData = { regime: parsed.regime ?? 'Unknown', date: parsed.date ?? '' };
} catch (e) {
  console.error('Error loading market context:', e);
}

let trades = [];
try {
  trades = JSON.parse(await fs.readFile(path.resolve('../data/trades.json'), 'utf-8'));
} catch (e) {
  console.error('Error loading trades:', e);
}

const reports = await getCollection('reports');
const pmSynthesis = reports.find((r) => r.slug === 'pm_synthesis');
const otherReports = reports.filter((r) => r.slug !== 'pm_synthesis');
---

<Layout title="AlphaOracle - Daily Analysis">
  <main>
    <header>
      <h1>AlphaOracle</h1>
      <p class="subtitle">Daily Analysis and Trade Recommendations</p>
      <div class={`regime-badge ${contextData.regime.toLowerCase().replace(' ', '-')}`}>
        {contextData.regime} Regime
      </div>
      <p class="date">Last updated: {contextData.date || 'N/A'}</p>
    </header>

    <section class="nav-grid">
      <a class="nav-card" href={`${base}portfolio/`}>
        <h2>Paper Trading Status</h2>
        <p>Account equity, positions, and latest execution results.</p>
      </a>
      <a class="nav-card" href={`${base}tickers/`}>
        <h2>Ticker Dashboard</h2>
        <p>Ticker-by-ticker metrics, technicals, and chart drill-downs.</p>
      </a>
    </section>

    {pmSynthesis && (
      <section class="panel">
        <div class="panel-head">
          <h2>Portfolio Manager Synthesis</h2>
          <a class="btn" href={`${base}reports/${pmSynthesis.slug}/`}>Open Full Report</a>
        </div>
        <p class="report-meta">{pmSynthesis.data.title} ({pmSynthesis.data.date})</p>
        <div class="analyst-links">
          {otherReports.map((report) => (
            <a href={`${base}reports/${report.slug}/`}>{report.data.title.replace(' Report', '')}</a>
          ))}
        </div>
      </section>
    )}

    <section class="panel">
      <h2>Today&apos;s Recommendations</h2>
      {trades.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Action</th>
              <th>Ticker</th>
              <th>Qty / Notional</th>
            </tr>
          </thead>
          <tbody>
            {trades.map((trade) => (
              <tr>
                <td>{(trade.action || '').toUpperCase()}</td>
                <td>{trade.ticker || '-'}</td>
                <td>{trade.notional_value ? `$${trade.notional_value}` : (trade.qty || '-')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="muted">No actionable recommendations for today.</p>
      )}
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    color: #f8f9fa;
  }
  header { text-align: center; margin-bottom: 2rem; }
  h1 { margin: 0; font-size: 3rem; font-weight: 800; }
  .subtitle { color: #8f949e; margin-top: 0.4rem; }
  .date { color: #8f949e; font-size: 0.9rem; margin-top: 0.5rem; }
  .regime-badge {
    display: inline-block;
    margin: 1rem 0 0.25rem;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .bull-quiet { background: rgba(40, 167, 69, 0.2); color: #28a745; border: 1px solid #28a745; }
  .bull-volatile { background: rgba(255, 193, 7, 0.2); color: #ffc107; border: 1px solid #ffc107; }
  .bear-quiet { background: rgba(220, 53, 69, 0.2); color: #dc3545; border: 1px solid #dc3545; }
  .bear-volatile { background: rgba(220, 53, 69, 0.3); color: #dc3545; border: 2px solid #dc3545; }
  .unknown { background: #2a2e39; color: #8f949e; }

  .nav-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .nav-card {
    text-decoration: none;
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 12px;
    padding: 1.25rem;
    color: inherit;
  }
  .nav-card:hover { border-color: #2962ff; }
  .nav-card h2 { margin: 0; font-size: 1.1rem; }
  .nav-card p { margin: 0.5rem 0 0; color: #8f949e; }

  .panel {
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .panel h2 { margin-top: 0; font-size: 1.2rem; }
  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .btn {
    text-decoration: none;
    color: #fff;
    background: #2962ff;
    border-radius: 8px;
    padding: 0.5rem 0.85rem;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .report-meta { margin: 0.5rem 0 0.75rem; color: #8f949e; }
  .analyst-links { display: flex; gap: 1rem; flex-wrap: wrap; }
  .analyst-links a { color: #c4d4ff; text-decoration: none; }
  .analyst-links a:hover { text-decoration: underline; }

  table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid #2a2e39;
  }
  th, td {
    border: 1px solid #2a2e39;
    padding: 0.7rem;
    text-align: left;
  }
  th { color: #8f949e; font-size: 0.8rem; text-transform: uppercase; }
  .muted { color: #8f949e; margin: 0; }
</style>
