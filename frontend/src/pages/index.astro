---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs/promises';
import path from 'node:path';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

let contextData = { regime: 'Unknown', date: '' };
try {
  const content = await fs.readFile(path.resolve('./public/data/market_context.json'), 'utf-8');
  const parsed = JSON.parse(content);
  contextData = { regime: parsed.regime ?? 'Unknown', date: parsed.date ?? '' };
} catch (e) {
  console.error('Error loading market context:', e);
}

let trades = [];
try {
  trades = JSON.parse(await fs.readFile(path.resolve('../data/trades.json'), 'utf-8'));
} catch (e) {
  console.error('Error loading trades:', e);
}

let indicators = null;
try {
  indicators = JSON.parse(await fs.readFile(path.resolve('./public/data/indicators.json'), 'utf-8'));
} catch (e) {
  console.error('Error loading indicators:', e);
}

const reports = await getCollection('reports');
const pmSynthesis = reports.find((r) => r.slug === 'pm_synthesis');
const reportBySlug = Object.fromEntries(reports.map((r) => [r.slug, r]));

const buyCount = trades.filter((t) => (t.action || '').toLowerCase() === 'buy').length;
const sellCount = trades.filter((t) => (t.action || '').toLowerCase() === 'sell').length;
const totalNotional = trades
  .filter((t) => (t.action || '').toLowerCase() === 'buy' && t.notional_value)
  .reduce((sum, t) => sum + Number(t.notional_value || 0), 0);

const bias = buyCount > sellCount ? 'Long bias' : sellCount > buyCount ? 'Risk-off / trim bias' : 'Neutral bias';
const digestItems = [
  `${bias} under a ${contextData.regime} regime.`,
  `Planned entries: ${buyCount}. Planned exits/reductions: ${sellCount}.`,
  `Target capital deployment today: $${totalNotional.toLocaleString(undefined, { maximumFractionDigits: 0 })}.`
];
---

<Layout title="AlphaOracle - Daily Analysis">
  <main>
    <header>
      <h1>AlphaOracle</h1>
      <p class="subtitle">AI-Powered Trading Analysis + Validated Rotation Strategies</p>
      <div class={`regime-badge ${contextData.regime.toLowerCase().replace(' ', '-')}`}>
        {contextData.regime} Regime
      </div>
      <p class="date">Last updated: {contextData.date || 'N/A'}</p>
    </header>

    {pmSynthesis && (
      <section class="panel">
        <div class="panel-head">
          <h2>Portfolio Manager Synthesis</h2>
          <a class="btn" href={`${base}reports/${pmSynthesis.slug}/`}>Open Full Report</a>
        </div>
        <p class="report-meta">{pmSynthesis.data.title} ({pmSynthesis.data.date})</p>
        <div class="analyst-links">
          {reportBySlug.macro && <a href={`${base}reports/macro/`}>Macro Strategist</a>}
          {reportBySlug.tech && <a href={`${base}reports/tech/`}>Technical Analyst</a>}
          {reportBySlug.risk && <a href={`${base}reports/risk/`}>Risk Manager</a>}
          <a href={`${base}portfolio-action-items/`}>Portfolio Action Items</a>
        </div>
      </section>
    )}

    {indicators && (
      <section class="panel">
        <div class="panel-head">
          <h2>Intermarket Analysis</h2>
          <a class="btn" href={`${base}indicators/`}>View Details</a>
        </div>
        <div class={`regime-indicator ${indicators.market_regime.regime.toLowerCase().replace(' ', '-')}`}>
          <div class="regime-main">
            <span class="regime-label">Market Regime:</span>
            <span class="regime-value">{indicators.market_regime.regime}</span>
            <span class="confidence-badge">{indicators.market_regime.confidence} confidence</span>
          </div>
          <p class="regime-interpretation">{indicators.market_regime.interpretation}</p>
        </div>
        <div class="indicators-grid">
          <div class="indicator-card">
            <div class="indicator-name">Risk Sentiment</div>
            <div class={`indicator-signal ${indicators.indicators.risk_sentiment.signal.replace('_', '-')}`}>
              {indicators.indicators.risk_sentiment.signal.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
            </div>
            <div class="indicator-details">
              SPY: {indicators.indicators.risk_sentiment.components.spy_trend} |
              VIX: {indicators.indicators.risk_sentiment.components.vix_value.toFixed(1)} ({indicators.indicators.risk_sentiment.components.vix_level})
            </div>
          </div>
          <div class="indicator-card">
            <div class="indicator-name">Dollar Strength</div>
            <div class={`indicator-signal ${indicators.indicators.dollar_strength.signal.replace('_', '-')}`}>
              {indicators.indicators.dollar_strength.signal.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
            </div>
            <div class="indicator-details">
              UUP: ${indicators.indicators.dollar_strength.components.uup_price.toFixed(2)} |
              Momentum: {indicators.indicators.dollar_strength.components.momentum > 0 ? '+' : ''}{indicators.indicators.dollar_strength.components.momentum.toFixed(1)}%
            </div>
          </div>
          <div class="indicator-card">
            <div class="indicator-name">Real Rates</div>
            <div class={`indicator-signal ${indicators.indicators.real_rates.signal.replace('_', '-')}`}>
              {indicators.indicators.real_rates.signal.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
            </div>
            <div class="indicator-details">
              TLT: ${indicators.indicators.real_rates.components.tlt_price.toFixed(2)} |
              Momentum: {indicators.indicators.real_rates.components.momentum > 0 ? '+' : ''}{indicators.indicators.real_rates.components.momentum.toFixed(1)}%
            </div>
          </div>
          <div class="indicator-card">
            <div class="indicator-name">Commodities</div>
            <div class={`indicator-signal ${indicators.indicators.commodity_strength.signal.replace('_', '-')}`}>
              {indicators.indicators.commodity_strength.signal.replace(/commodities_/g, '').replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
            </div>
            <div class="indicator-details">
              GLD: {indicators.indicators.commodity_strength.components.gld.trend} |
              XLE: {indicators.indicators.commodity_strength.components.xle.trend}
            </div>
          </div>
        </div>
      </section>
    )}

    <section class="nav-grid">
      <a class="nav-card" href={`${base}indicators/`}>
        <h2>Intermarket Indicators</h2>
        <p>7-market regime detection using SPY, VIX, TLT, UUP, GLD, SLV, XLE.</p>
      </a>
      <a class="nav-card" href={`${base}paper-trading/`}>
        <h2>Paper Trading Dashboard</h2>
        <p>Mode 3: Track forward performance of 7 strategies with $100k each.</p>
      </a>
      <a class="nav-card" href={`${base}portfolio/`}>
        <h2>Live Portfolio Status</h2>
        <p>Real broker account positions and execution logs.</p>
      </a>
      <a class="nav-card" href={`${base}tickers/`}>
        <h2>Ticker Dashboard</h2>
        <p>Per-ticker metrics, technicals, strategy ratings, and chart drill-downs.</p>
      </a>
      <a class="nav-card" href={`${base}backtests/`}>
        <h2>Strategy Backtests</h2>
        <p>33-year validation: Reddit vs regime rotation, tolerance bands, tax impact.</p>
      </a>
    </section>

    <section class="panel">
      <h2>Today&apos;s Actionable Digest</h2>
      <ul class="digest">
        {digestItems.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <p class="muted">Details by ticker are in the <a href={`${base}tickers/`}>Ticker Dashboard</a>.</p>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    color: #f8f9fa;
  }
  header { text-align: center; margin-bottom: 2rem; }
  h1 { margin: 0; font-size: 3rem; font-weight: 800; }
  .subtitle { color: #8f949e; margin-top: 0.4rem; }
  .date { color: #8f949e; font-size: 0.9rem; margin-top: 0.5rem; }
  .regime-badge {
    display: inline-block;
    margin: 1rem 0 0.25rem;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .bull-quiet { background: rgba(40, 167, 69, 0.2); color: #28a745; border: 1px solid #28a745; }
  .bull-volatile { background: rgba(255, 193, 7, 0.2); color: #ffc107; border: 1px solid #ffc107; }
  .bear-quiet { background: rgba(220, 53, 69, 0.2); color: #dc3545; border: 1px solid #dc3545; }
  .bear-volatile { background: rgba(220, 53, 69, 0.3); color: #dc3545; border: 2px solid #dc3545; }
  .unknown { background: #2a2e39; color: #8f949e; }

  .nav-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .nav-card {
    text-decoration: none;
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 12px;
    padding: 1.25rem;
    color: inherit;
  }
  .nav-card:hover { border-color: #2962ff; }
  .nav-card h2 { margin: 0; font-size: 1.1rem; }
  .nav-card p { margin: 0.5rem 0 0; color: #8f949e; }

  .panel {
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .panel h2 { margin-top: 0; font-size: 1.2rem; }
  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .btn {
    text-decoration: none;
    color: #fff;
    background: #2962ff;
    border-radius: 8px;
    padding: 0.5rem 0.85rem;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .report-meta { margin: 0.5rem 0 0.75rem; color: #8f949e; }
  .analyst-links { display: flex; gap: 1rem; flex-wrap: wrap; }
  .analyst-links a { color: #c4d4ff; text-decoration: none; }
  .analyst-links a:hover { text-decoration: underline; }

  .digest {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.45rem;
  }
  .digest li { color: #d1d4dc; }
  .muted { color: #8f949e; margin: 0.8rem 0 0; }
  .muted a { color: #c4d4ff; text-decoration: none; }
  .muted a:hover { text-decoration: underline; }

  /* Intermarket Indicators */
  .regime-indicator {
    background: #1e2230;
    border-radius: 8px;
    padding: 1rem;
    margin: 1rem 0;
  }
  .regime-indicator.bear-volatile {
    border: 2px solid rgba(220, 53, 69, 0.4);
  }
  .regime-indicator.bear-quiet {
    border: 2px solid rgba(220, 53, 69, 0.3);
  }
  .regime-indicator.bull-volatile {
    border: 2px solid rgba(255, 193, 7, 0.4);
  }
  .regime-indicator.bull-quiet {
    border: 2px solid rgba(40, 167, 69, 0.4);
  }
  .regime-main {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .regime-label {
    color: #8f949e;
    font-size: 0.9rem;
  }
  .regime-value {
    font-size: 1.3rem;
    font-weight: 700;
    color: #f8f9fa;
  }
  .confidence-badge {
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    color: #8f949e;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .regime-interpretation {
    color: #c4d4ff;
    font-size: 0.9rem;
    margin: 0;
  }

  .indicators-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .indicator-card {
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 8px;
    padding: 0.85rem;
  }
  .indicator-name {
    font-size: 0.85rem;
    color: #8f949e;
    margin-bottom: 0.4rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .indicator-signal {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .indicator-signal.risk-on { color: #28a745; }
  .indicator-signal.risk-off { color: #dc3545; }
  .indicator-signal.cautious { color: #ffc107; }
  .indicator-signal.strong-dollar { color: #2962ff; }
  .indicator-signal.weak-dollar { color: #f8961e; }
  .indicator-signal.rising-rates { color: #dc3545; }
  .indicator-signal.falling-rates { color: #28a745; }
  .indicator-signal.stable-rates { color: #8f949e; }
  .indicator-signal.strong-defensive { color: #ffc107; }
  .indicator-signal.strong-cyclical { color: #28a745; }
  .indicator-details {
    font-size: 0.8rem;
    color: #8f949e;
  }
</style>
