---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs/promises';
import path from 'node:path';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

let positions = {
  initialized_at: '',
  updated_at: '',
  strategies: {}
};

let performance = {
  updated_at: '',
  period_start: '',
  period_end: '',
  strategies: {},
  rankings: { by_total_return: [], by_sharpe: [] }
};

let trades = { trades: [] };
let alpacaTrades = { ok: false, trades: [], error: '' };

try {
  positions = JSON.parse(await fs.readFile(path.resolve('./public/data/paper_positions.json'), 'utf-8'));
} catch {
  console.log('No paper_positions.json found');
}

try {
  performance = JSON.parse(await fs.readFile(path.resolve('./public/data/paper_performance.json'), 'utf-8'));
} catch {
  console.log('No paper_performance.json found');
}

try {
  trades = JSON.parse(await fs.readFile(path.resolve('./public/data/paper_trades.json'), 'utf-8'));
} catch {
  console.log('No paper_trades.json found');
}

// Try to load real Alpaca trade history
try {
  alpacaTrades = JSON.parse(await fs.readFile(path.resolve('./public/data/alpaca_trades.json'), 'utf-8'));
} catch {
  console.log('No alpaca_trades.json found');
}

const formatDate = (isoString: string) => {
  if (!isoString) return 'N/A';
  return new Date(isoString).toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};

const formatPercent = (value: number) => {
  const sign = value >= 0 ? '+' : '';
  return `${sign}${(value * 100).toFixed(2)}%`;
};

const formatCurrency = (value: number) => {
  return `$${value.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
};

// Use real Alpaca trades if available, otherwise fall back to simulated
const recentTrades = alpacaTrades.ok && alpacaTrades.trades.length > 0
  ? alpacaTrades.trades.slice(0, 20)  // Already sorted by most recent
  : trades.trades.slice(-20).reverse();
---

<Layout title="AlphaOracle - Paper Trading">
  <main>
    <nav>
      <a href={base}>← Back to Analysis</a>
      <a href={`${base}backtests/`}>Backtests</a>
    </nav>

    <header>
      <h1>📊 Paper Trading Dashboard</h1>
      <p class="muted">Mode 3: Forward Performance Tracking</p>
      <p class="muted">Period: {formatDate(performance.period_start)} - {formatDate(performance.period_end)}</p>
    </header>

    <!-- Performance Rankings -->
    <section class="panel">
      <h2>🏆 Strategy Rankings by Total Return</h2>
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Strategy</th>
            <th>Return</th>
            <th>Portfolio Value</th>
            <th>Positions</th>
            <th>Equity %</th>
          </tr>
        </thead>
        <tbody>
          {performance.rankings.by_total_return.map((item, idx) => {
            const stratPerf = performance.strategies[item.strategy];
            return (
              <tr>
                <td>{idx + 1}</td>
                <td>
                  <a href={`${base}paper-trading/${item.strategy}/`} class="strategy-link">
                    <strong>{item.strategy.replace(/_/g, ' ')}</strong>
                  </a>
                </td>
                <td class={item.return_pct >= 0 ? 'positive' : 'negative'}>
                  {formatPercent(item.return_pct)}
                </td>
                <td>{formatCurrency(stratPerf.current_value)}</td>
                <td>{stratPerf.current_positions}</td>
                <td>{formatPercent(stratPerf.equity_pct)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </section>

    <!-- Strategy Details -->
    <section class="panel">
      <h2>📈 Strategy Details</h2>
      {Object.entries(positions.strategies).map(([strategyName, strategy]) => {
        const perf = performance.strategies[strategyName];
        const hasPositions = Object.keys(strategy.current_positions).length > 0;

        return (
          <div class="strategy-card">
            <div class="strategy-header">
              <h3>{strategyName.replace(/_/g, ' ')}</h3>
              <div class="strategy-kpis">
                <div>
                  <span>Portfolio Value</span>
                  <strong>{formatCurrency(strategy.total_portfolio_value)}</strong>
                </div>
                <div>
                  <span>Return</span>
                  <strong class={strategy.total_return >= 0 ? 'positive' : 'negative'}>
                    {formatPercent(strategy.total_return_pct)}
                  </strong>
                </div>
                <div>
                  <span>Cash</span>
                  <strong>{formatCurrency(strategy.current_cash)}</strong>
                </div>
                <div>
                  <span>Trades</span>
                  <strong>{perf.trades_executed}</strong>
                </div>
              </div>
            </div>

            {hasPositions ? (
              <table class="positions-table">
                <thead>
                  <tr>
                    <th>Ticker</th>
                    <th>Shares</th>
                    <th>Entry Price</th>
                    <th>Current Price</th>
                    <th>Market Value</th>
                    <th>Unrealized P/L</th>
                    <th>Entry Date</th>
                  </tr>
                </thead>
                <tbody>
                  {Object.entries(strategy.current_positions).map(([ticker, position]) => (
                    <tr>
                      <td><strong>{ticker}</strong></td>
                      <td>{position.shares.toFixed(2)}</td>
                      <td>{formatCurrency(position.avg_entry_price)}</td>
                      <td>{formatCurrency(position.current_price)}</td>
                      <td>{formatCurrency(position.market_value)}</td>
                      <td class={position.unrealized_pnl >= 0 ? 'positive' : 'negative'}>
                        {formatCurrency(position.unrealized_pnl)} ({formatPercent(position.unrealized_pnl_pct)})
                      </td>
                      <td>{position.entry_date}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            ) : (
              <div class="status-message">
                <p class="status-text">{strategy.status_message || "No open positions - waiting for entry signal"}</p>
              </div>
            )}
          </div>
        );
      })}
    </section>

    <!-- Recent Trades -->
    <section class="panel">
      <h2>📝 Recent Trades (Last 20)
        {alpacaTrades.ok && <span class="badge-live">Live from Alpaca</span>}
      </h2>
      {recentTrades.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Timestamp</th>
              {!alpacaTrades.ok && <th>Strategy</th>}
              <th>Action</th>
              <th>Ticker</th>
              <th>Shares</th>
              <th>Price</th>
              <th>Notional</th>
              {!alpacaTrades.ok && <th>Rationale</th>}
              {alpacaTrades.ok && <th>Type</th>}
            </tr>
          </thead>
          <tbody>
            {recentTrades.map((trade) => (
              <tr>
                <td>{formatDate(trade.timestamp)}</td>
                {!alpacaTrades.ok && <td>{trade.strategy?.replace(/_/g, ' ')}</td>}
                <td class={trade.side === 'buy' || trade.action === 'buy' ? 'buy-action' : 'sell-action'}>
                  {(trade.side || trade.action || '').toUpperCase()}
                </td>
                <td><strong>{trade.symbol || trade.ticker}</strong></td>
                <td>{trade.qty?.toFixed(2) || trade.shares?.toFixed(2)}</td>
                <td>{formatCurrency(trade.price)}</td>
                <td>{formatCurrency(trade.notional)}</td>
                {!alpacaTrades.ok && <td class="rationale">{trade.rationale}</td>}
                {alpacaTrades.ok && <td>{trade.type}</td>}
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="muted">No trades executed yet</p>
      )}
    </section>

    <footer class="info-footer">
      <p><strong>About Paper Trading:</strong> Virtual portfolios track strategy performance without risking capital.
      Each strategy starts with $100,000 and executes trades based on signals. Performance is updated daily with live market data.</p>
      <p class="muted">Last updated: {formatDate(positions.updated_at)}</p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
    color: #f8f9fa;
  }

  nav {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  nav a {
    color: #c4d4ff;
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }

  header {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .muted {
    color: #8f949e;
    font-size: 0.9rem;
  }

  .panel {
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
  }

  th, td {
    text-align: left;
    padding: 0.75rem;
    border-bottom: 1px solid #2a2e39;
  }

  th {
    background: #1e2230;
    font-weight: 600;
    color: #8f949e;
  }

  tbody tr:hover {
    background: #1e2230;
  }

  .positive {
    color: #22c55e;
    font-weight: 600;
  }

  .negative {
    color: #ef4444;
    font-weight: 600;
  }

  .strategy-link {
    color: #f8f9fa;
    text-decoration: none;
    transition: color 0.2s;
  }

  .strategy-link:hover {
    color: #2962ff;
    text-decoration: underline;
  }

  .strategy-card {
    border: 1px solid #2a2e39;
    border-radius: 6px;
    padding: 1rem;
    margin-bottom: 1rem;
    background: #0d111b;
  }

  .strategy-header {
    margin-bottom: 1rem;
  }

  .strategy-header h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    text-transform: capitalize;
    color: #f8f9fa;
  }

  .strategy-kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .strategy-kpis > div {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .strategy-kpis span {
    font-size: 0.85rem;
    color: #8f949e;
  }

  .strategy-kpis strong {
    font-size: 1.1rem;
    color: #f8f9fa;
  }

  .positions-table {
    margin-top: 1rem;
    font-size: 0.9rem;
  }

  .buy-action {
    color: #22c55e;
    font-weight: 600;
  }

  .sell-action {
    color: #ef4444;
    font-weight: 600;
  }

  .rationale {
    font-size: 0.85rem;
    color: #8f949e;
    max-width: 300px;
  }

  .info-footer {
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 6px;
    padding: 1rem;
    margin-top: 2rem;
  }

  .info-footer p {
    margin: 0.5rem 0;
    color: #d1d4dc;
  }

  .badge-live {
    display: inline-block;
    background: #28a745;
    color: white;
    font-size: 0.7rem;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    margin-left: 0.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .status-message {
    background: rgba(255, 193, 7, 0.1);
    border-left: 3px solid #ffc107;
    padding: 1rem;
    border-radius: 4px;
    margin-top: 0.5rem;
  }

  .status-text {
    margin: 0;
    color: #f8f9fa;
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    main {
      padding: 1rem;
    }

    table {
      font-size: 0.85rem;
    }

    th, td {
      padding: 0.5rem;
    }

    .strategy-kpis {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
