---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs/promises';
import path from 'node:path';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

let positions = {
  initialized_at: '',
  updated_at: '',
  strategies: {}
};

let performance = {
  updated_at: '',
  period_start: '',
  period_end: '',
  strategies: {},
  rankings: { by_total_return: [], by_sharpe: [] }
};

let trades = { trades: [] };

try {
  positions = JSON.parse(await fs.readFile(path.resolve('./public/data/paper_positions.json'), 'utf-8'));
} catch {
  console.log('No paper_positions.json found');
}

try {
  performance = JSON.parse(await fs.readFile(path.resolve('./public/data/paper_performance.json'), 'utf-8'));
} catch {
  console.log('No paper_performance.json found');
}

try {
  trades = JSON.parse(await fs.readFile(path.resolve('./public/data/paper_trades.json'), 'utf-8'));
} catch {
  console.log('No paper_trades.json found');
}

const formatDate = (isoString: string) => {
  if (!isoString) return 'N/A';
  return new Date(isoString).toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};

const formatPercent = (value: number) => {
  const sign = value >= 0 ? '+' : '';
  return `${sign}${(value * 100).toFixed(2)}%`;
};

const formatCurrency = (value: number) => {
  return `$${value.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
};

// Get recent trades (last 20)
const recentTrades = trades.trades.slice(-20).reverse();
---

<Layout title="AlphaOracle - Paper Trading">
  <main>
    <nav>
      <a href={base}>← Back to Analysis</a>
      <a href={`${base}backtests/`}>Backtests</a>
      <a href={`${base}portfolio/`}>Live Portfolio</a>
    </nav>

    <header>
      <h1>📊 Paper Trading Dashboard</h1>
      <p class="muted">Mode 3: Forward Performance Tracking</p>
      <p class="muted">Period: {formatDate(performance.period_start)} - {formatDate(performance.period_end)}</p>
    </header>

    <!-- Performance Rankings -->
    <section class="panel">
      <h2>🏆 Strategy Rankings by Total Return</h2>
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Strategy</th>
            <th>Return</th>
            <th>Portfolio Value</th>
            <th>Positions</th>
            <th>Equity %</th>
          </tr>
        </thead>
        <tbody>
          {performance.rankings.by_total_return.map((item, idx) => {
            const stratPerf = performance.strategies[item.strategy];
            return (
              <tr>
                <td>{idx + 1}</td>
                <td><strong>{item.strategy.replace(/_/g, ' ')}</strong></td>
                <td class={item.return_pct >= 0 ? 'positive' : 'negative'}>
                  {formatPercent(item.return_pct)}
                </td>
                <td>{formatCurrency(stratPerf.current_value)}</td>
                <td>{stratPerf.current_positions}</td>
                <td>{formatPercent(stratPerf.equity_pct)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </section>

    <!-- Strategy Details -->
    <section class="panel">
      <h2>📈 Strategy Details</h2>
      {Object.entries(positions.strategies).map(([strategyName, strategy]) => {
        const perf = performance.strategies[strategyName];
        const hasPositions = Object.keys(strategy.current_positions).length > 0;

        return (
          <div class="strategy-card">
            <div class="strategy-header">
              <h3>{strategyName.replace(/_/g, ' ')}</h3>
              <div class="strategy-kpis">
                <div>
                  <span>Portfolio Value</span>
                  <strong>{formatCurrency(strategy.total_portfolio_value)}</strong>
                </div>
                <div>
                  <span>Return</span>
                  <strong class={strategy.total_return >= 0 ? 'positive' : 'negative'}>
                    {formatPercent(strategy.total_return_pct)}
                  </strong>
                </div>
                <div>
                  <span>Cash</span>
                  <strong>{formatCurrency(strategy.current_cash)}</strong>
                </div>
                <div>
                  <span>Trades</span>
                  <strong>{perf.trades_executed}</strong>
                </div>
              </div>
            </div>

            {hasPositions ? (
              <table class="positions-table">
                <thead>
                  <tr>
                    <th>Ticker</th>
                    <th>Shares</th>
                    <th>Entry Price</th>
                    <th>Current Price</th>
                    <th>Market Value</th>
                    <th>Unrealized P/L</th>
                    <th>Entry Date</th>
                  </tr>
                </thead>
                <tbody>
                  {Object.entries(strategy.current_positions).map(([ticker, position]) => (
                    <tr>
                      <td><strong>{ticker}</strong></td>
                      <td>{position.shares.toFixed(2)}</td>
                      <td>{formatCurrency(position.avg_entry_price)}</td>
                      <td>{formatCurrency(position.current_price)}</td>
                      <td>{formatCurrency(position.market_value)}</td>
                      <td class={position.unrealized_pnl >= 0 ? 'positive' : 'negative'}>
                        {formatCurrency(position.unrealized_pnl)} ({formatPercent(position.unrealized_pnl_pct)})
                      </td>
                      <td>{position.entry_date}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            ) : (
              <p class="muted">No open positions</p>
            )}
          </div>
        );
      })}
    </section>

    <!-- Recent Trades -->
    <section class="panel">
      <h2>📝 Recent Trades (Last 20)</h2>
      {recentTrades.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Timestamp</th>
              <th>Strategy</th>
              <th>Action</th>
              <th>Ticker</th>
              <th>Shares</th>
              <th>Price</th>
              <th>Notional</th>
              <th>Rationale</th>
            </tr>
          </thead>
          <tbody>
            {recentTrades.map((trade) => (
              <tr>
                <td>{formatDate(trade.timestamp)}</td>
                <td>{trade.strategy.replace(/_/g, ' ')}</td>
                <td class={trade.action === 'buy' ? 'buy-action' : 'sell-action'}>
                  {trade.action.toUpperCase()}
                </td>
                <td><strong>{trade.ticker}</strong></td>
                <td>{trade.shares.toFixed(2)}</td>
                <td>{formatCurrency(trade.price)}</td>
                <td>{formatCurrency(trade.notional)}</td>
                <td class="rationale">{trade.rationale}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="muted">No trades executed yet</p>
      )}
    </section>

    <footer class="info-footer">
      <p><strong>About Paper Trading:</strong> Virtual portfolios track strategy performance without risking capital.
      Each strategy starts with $100,000 and executes trades based on signals. Performance is updated daily with live market data.</p>
      <p class="muted">Last updated: {formatDate(positions.updated_at)}</p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }

  nav {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  nav a {
    color: #0066cc;
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }

  header {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .muted {
    color: #666;
    font-size: 0.9rem;
  }

  .panel {
    background: white;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
  }

  th, td {
    text-align: left;
    padding: 0.75rem;
    border-bottom: 1px solid #eee;
  }

  th {
    background: #f5f5f5;
    font-weight: 600;
  }

  tbody tr:hover {
    background: #f9f9f9;
  }

  .positive {
    color: #22c55e;
    font-weight: 600;
  }

  .negative {
    color: #ef4444;
    font-weight: 600;
  }

  .strategy-card {
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .strategy-header {
    margin-bottom: 1rem;
  }

  .strategy-header h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    text-transform: capitalize;
  }

  .strategy-kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .strategy-kpis > div {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .strategy-kpis span {
    font-size: 0.85rem;
    color: #666;
  }

  .strategy-kpis strong {
    font-size: 1.1rem;
  }

  .positions-table {
    margin-top: 1rem;
    font-size: 0.9rem;
  }

  .buy-action {
    color: #22c55e;
    font-weight: 600;
  }

  .sell-action {
    color: #ef4444;
    font-weight: 600;
  }

  .rationale {
    font-size: 0.85rem;
    color: #555;
    max-width: 300px;
  }

  .info-footer {
    background: #f8f9fa;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 1rem;
    margin-top: 2rem;
  }

  .info-footer p {
    margin: 0.5rem 0;
  }

  @media (max-width: 768px) {
    main {
      padding: 1rem;
    }

    table {
      font-size: 0.85rem;
    }

    th, td {
      padding: 0.5rem;
    }

    .strategy-kpis {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
