---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs/promises';
import path from 'node:path';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

let alpacaTrades = { ok: false, trades: [], error: '' };
let alpacaPortfolio = { ok: false, account: null, positions: [], error: '', paper_trading: false, last_updated_utc: '' };

// Load real Alpaca trade history
try {
  alpacaTrades = JSON.parse(await fs.readFile(path.resolve('./public/data/alpaca_trades.json'), 'utf-8'));
} catch {
  console.log('No alpaca_trades.json found');
}

// Load real Alpaca portfolio (Dev account)
try {
  alpacaPortfolio = JSON.parse(await fs.readFile(path.resolve('./public/data/portfolio_status.json'), 'utf-8'));
} catch {
  console.log('No portfolio_status.json found');
}

const formatDate = (isoString: string) => {
  if (!isoString) return 'N/A';
  return new Date(isoString).toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};

const formatPercent = (value: number) => {
  const sign = value >= 0 ? '+' : '';
  return `${sign}${(value * 100).toFixed(2)}%`;
};

const formatCurrency = (value: number) => {
  return `$${value.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
};

const recentTrades = alpacaTrades.ok && alpacaTrades.trades.length > 0
  ? alpacaTrades.trades.slice(0, 20)
  : [];
---

<Layout title="AlphaOracle - Paper Trading">
  <main>
    <nav>
      <a href={base}>← Back to Analysis</a>
      <a href={`${base}backtests/`}>Backtests</a>
    </nav>

    <header>
      <h1>📊 Paper Trading Dashboard</h1>
      <p class="muted">Real-time Alpaca Paper Trading Accounts</p>
      {alpacaPortfolio.last_updated_utc && (
        <p class="muted">Last updated: {formatDate(alpacaPortfolio.last_updated_utc)}</p>
      )}
    </header>

    <!-- Alpaca Dev Account (Live Paper Trading) -->
    {alpacaPortfolio.ok && alpacaPortfolio.account ? (
      <section class="panel">
        <h2>📡 Alpaca Dev Account (Advanced LLM Strategy)
          <span class="badge-live">Live Data</span>
        </h2>
        <p class="muted" style="margin-bottom: 1rem;">
          Sophisticated LLM agent trading 2x daily (10 AM & 3:30 PM ET) with multi-source analysis and dynamic position sizing
        </p>
        <div class="strategy-kpis" style="margin-bottom: 1rem;">
          <div>
            <span>Portfolio Value</span>
            <strong>{formatCurrency(alpacaPortfolio.account.portfolio_value)}</strong>
          </div>
          <div>
            <span>Cash</span>
            <strong>{formatCurrency(alpacaPortfolio.account.cash)}</strong>
          </div>
          <div>
            <span>Equity (Positions)</span>
            <strong>{formatCurrency(alpacaPortfolio.account.equity)}</strong>
          </div>
          <div>
            <span>Buying Power</span>
            <strong>{formatCurrency(alpacaPortfolio.account.buying_power)}</strong>
          </div>
        </div>

        {alpacaPortfolio.positions.length > 0 ? (
          <table class="positions-table">
            <thead>
              <tr>
                <th>Ticker</th>
                <th>Shares</th>
                <th>Entry Price</th>
                <th>Current Price</th>
                <th>Market Value</th>
                <th>Unrealized P/L</th>
              </tr>
            </thead>
            <tbody>
              {alpacaPortfolio.positions.map((position) => (
                <tr>
                  <td><strong>{position.symbol}</strong></td>
                  <td>{position.qty.toFixed(2)}</td>
                  <td>{formatCurrency(position.avg_entry_price)}</td>
                  <td>{formatCurrency(position.current_price)}</td>
                  <td>{formatCurrency(position.market_value)}</td>
                  <td class={position.unrealized_pl >= 0 ? 'positive' : 'negative'}>
                    {formatCurrency(position.unrealized_pl)}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <div class="status-message">
            <p class="status-text">No open positions - 100% cash</p>
          </div>
        )}
      </section>
    ) : (
      <section class="panel">
        <h2>📡 Alpaca Dev Account</h2>
        <div class="status-message">
          <p class="status-text">⚠️ Unable to load Alpaca portfolio data. Check if fetch_alpaca_portfolio.py ran successfully.</p>
        </div>
      </section>
    )}

    <!-- Recent Trades -->
    <section class="panel">
      <h2>📝 Recent Trades from Alpaca Dev Account (Last 20)
        {alpacaTrades.ok && <span class="badge-live">Live Data</span>}
      </h2>
      {recentTrades.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Timestamp</th>
              <th>Action</th>
              <th>Ticker</th>
              <th>Shares</th>
              <th>Price</th>
              <th>Notional</th>
              <th>Type</th>
            </tr>
          </thead>
          <tbody>
            {recentTrades.map((trade) => (
              <tr>
                <td>{formatDate(trade.timestamp)}</td>
                <td class={trade.side === 'buy' ? 'buy-action' : 'sell-action'}>
                  {trade.side.toUpperCase()}
                </td>
                <td><strong>{trade.symbol}</strong></td>
                <td>{trade.qty.toFixed(2)}</td>
                <td>{formatCurrency(trade.price)}</td>
                <td>{formatCurrency(trade.notional)}</td>
                <td>{trade.type}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <div class="status-message">
          <p class="status-text">No trades executed yet on the Alpaca Dev account</p>
        </div>
      )}
    </section>

    <footer class="info-footer">
      <p><strong>About Paper Trading:</strong> All 6 Alpaca accounts (Dev, PROD_1-5) are paper trading accounts using Alpaca's API.
      No real capital is at risk. The system executes trades automatically based on LLM analysis and rule-based strategies.</p>
      <p><strong>Dev Account:</strong> Advanced LLM strategy with 2x daily execution (10 AM & 3:30 PM ET)</p>
      <p><strong>PROD_1:</strong> Standard LLM strategy with EOD execution (3:30 PM ET only)</p>
      <p><strong>PROD_2-5:</strong> Rule-based strategies (TQQQ Momentum, Dual Momentum, Sector Rotation, Mean Reversion) - EOD only</p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
    color: #f8f9fa;
  }

  nav {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  nav a {
    color: #c4d4ff;
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }

  header {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .muted {
    color: #8f949e;
    font-size: 0.9rem;
  }

  .panel {
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
  }

  th, td {
    text-align: left;
    padding: 0.75rem;
    border-bottom: 1px solid #2a2e39;
  }

  th {
    background: #1e2230;
    font-weight: 600;
    color: #8f949e;
  }

  tbody tr:hover {
    background: #1e2230;
  }

  .positive {
    color: #22c55e;
    font-weight: 600;
  }

  .negative {
    color: #ef4444;
    font-weight: 600;
  }

  .strategy-link {
    color: #f8f9fa;
    text-decoration: none;
    transition: color 0.2s;
  }

  .strategy-link:hover {
    color: #2962ff;
    text-decoration: underline;
  }

  .strategy-card {
    border: 1px solid #2a2e39;
    border-radius: 6px;
    padding: 1rem;
    margin-bottom: 1rem;
    background: #0d111b;
  }

  .strategy-header {
    margin-bottom: 1rem;
  }

  .strategy-header h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    text-transform: capitalize;
    color: #f8f9fa;
  }

  .strategy-kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .strategy-kpis > div {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .strategy-kpis span {
    font-size: 0.85rem;
    color: #8f949e;
  }

  .strategy-kpis strong {
    font-size: 1.1rem;
    color: #f8f9fa;
  }

  .positions-table {
    margin-top: 1rem;
    font-size: 0.9rem;
  }

  .buy-action {
    color: #22c55e;
    font-weight: 600;
  }

  .sell-action {
    color: #ef4444;
    font-weight: 600;
  }

  .rationale {
    font-size: 0.85rem;
    color: #8f949e;
    max-width: 300px;
  }

  .info-footer {
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 6px;
    padding: 1rem;
    margin-top: 2rem;
  }

  .info-footer p {
    margin: 0.5rem 0;
    color: #d1d4dc;
  }

  .badge-live {
    display: inline-block;
    background: #28a745;
    color: white;
    font-size: 0.7rem;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    margin-left: 0.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .status-message {
    background: rgba(255, 193, 7, 0.1);
    border-left: 3px solid #ffc107;
    padding: 1rem;
    border-radius: 4px;
    margin-top: 0.5rem;
  }

  .status-text {
    margin: 0;
    color: #f8f9fa;
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    main {
      padding: 1rem;
    }

    table {
      font-size: 0.85rem;
    }

    th, td {
      padding: 0.5rem;
    }

    .strategy-kpis {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
