---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs/promises';
import path from 'node:path';

const { strategy } = Astro.params;

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// Load paper trading data
let performance = {
  updated_at: '',
  period_start: '',
  period_end: '',
  strategies: {}
};

let positions = {
  strategies: {}
};

let alpacaTrades = {
  ok: false,
  trades: []
};

try {
  performance = JSON.parse(await fs.readFile(path.resolve('./public/data/paper_performance.json'), 'utf-8'));
} catch {
  console.log('No paper_performance.json found');
}

try {
  positions = JSON.parse(await fs.readFile(path.resolve('./public/data/paper_positions.json'), 'utf-8'));
} catch {
  console.log('No paper_positions.json found');
}

try {
  alpacaTrades = JSON.parse(await fs.readFile(path.resolve('./public/data/alpaca_trades.json'), 'utf-8'));
} catch {
  console.log('No alpaca_trades.json found');
}

// Get strategy data
const strategyData = positions.strategies[strategy];
const strategyPerf = performance.strategies[strategy];

if (!strategyData) {
  return Astro.redirect(`${base}paper-trading/`);
}

// Get strategy-specific trades from Alpaca
const strategyTrades = alpacaTrades.ok
  ? alpacaTrades.trades.filter(trade => {
      // Map strategy to expected symbols
      const strategySymbols = {
        'TQQQ_Momentum': ['TQQQ'],
        'Dual_Momentum': ['SPY', 'QQQ', 'GLD'],
        'Sector_Rotation': ['XLE', 'XLF', 'XLV', 'XLI', 'XLK', 'XLU', 'XLP', 'XLY', 'XLB'],
        'Mean_Reversion': ['SPY'],
        'LLM_Strategy': [] // All symbols possible
      };

      const symbols = strategySymbols[strategy] || [];
      return symbols.length === 0 || symbols.includes(trade.symbol);
    })
  : [];

// Build chart data from daily snapshots
let chartData = {
  dates: [],
  portfolioValues: [],
  trades: []
};

// Try to load daily snapshots
try {
  const snapshotsDir = path.resolve('./public/data/paper_trading/daily_snapshots');
  const files = await fs.readdir(snapshotsDir);
  const snapshotFiles = files.filter(f => f.endsWith('.json')).sort();

  for (const file of snapshotFiles) {
    const snapshot = JSON.parse(
      await fs.readFile(path.join(snapshotsDir, file), 'utf-8')
    );

    if (snapshot.strategies && snapshot.strategies[strategy]) {
      const stratSnap = snapshot.strategies[strategy];
      chartData.dates.push(file.replace('.json', ''));
      chartData.portfolioValues.push(stratSnap.total_portfolio_value || 0);
    }
  }
} catch (error) {
  console.log('No daily snapshots found:', error);
}

// Add trade markers
strategyTrades.forEach(trade => {
  const tradeDate = trade.timestamp.split('T')[0];
  const dateIndex = chartData.dates.indexOf(tradeDate);

  if (dateIndex !== -1) {
    chartData.trades.push({
      date: tradeDate,
      dateIndex,
      value: chartData.portfolioValues[dateIndex],
      side: trade.side,
      symbol: trade.symbol,
      qty: trade.qty,
      price: trade.price
    });
  }
});

const formatCurrency = (value) => {
  if (value === null || value === undefined) return '$0.00';
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(value);
};

const formatPercent = (value) => {
  if (value === null || value === undefined) return '0.00%';
  return `${value >= 0 ? '+' : ''}${value.toFixed(2)}%`;
};

const formatDate = (isoString) => {
  if (!isoString) return 'N/A';
  try {
    return new Date(isoString).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    });
  } catch {
    return 'N/A';
  }
};

const strategyName = strategy.replace(/_/g, ' ');
const hasChartData = chartData.dates.length > 0;
---

<Layout title={`AlphaOracle - ${strategyName}`}>
  <main>
    <nav>
      <a href={`${base}paper-trading/`}>← Back to Paper Trading</a>
      <a href={base}>Analysis Dashboard</a>
    </nav>

    <header>
      <h1>📊 {strategyName}</h1>
      <p class="subtitle">Paper Trading Performance</p>
      <p class="muted">Period: {formatDate(performance.period_start)} - {formatDate(performance.period_end)}</p>
    </header>

    <!-- Performance Metrics -->
    <section class="panel metrics-panel">
      <div class="metrics-grid">
        <div class="metric-card">
          <span class="label">Portfolio Value</span>
          <span class="value">{formatCurrency(strategyData.total_portfolio_value)}</span>
        </div>
        <div class="metric-card">
          <span class="label">Total Return</span>
          <span class={`value ${strategyData.total_return >= 0 ? 'positive' : 'negative'}`}>
            {formatPercent(strategyData.total_return_pct)}
          </span>
          <span class="subvalue">{formatCurrency(strategyData.total_return)}</span>
        </div>
        <div class="metric-card">
          <span class="label">Cash</span>
          <span class="value">{formatCurrency(strategyData.current_cash)}</span>
          <span class="subvalue">{formatPercent(strategyPerf.equity_pct)} in equity</span>
        </div>
        <div class="metric-card">
          <span class="label">Trades</span>
          <span class="value">{strategyPerf.trades_executed}</span>
        </div>
        <div class="metric-card">
          <span class="label">Open Positions</span>
          <span class="value">{strategyPerf.current_positions}</span>
        </div>
        <div class="metric-card">
          <span class="label">Starting Capital</span>
          <span class="value">{formatCurrency(strategyPerf.starting_capital)}</span>
        </div>
      </div>
    </section>

    <!-- Performance Chart -->
    <section class="panel">
      <h2>Performance Chart</h2>
      {hasChartData ? (
        <div class="chart-container">
          <canvas id="performance-chart"></canvas>
        </div>
      ) : (
        <div class="no-data">
          <p>📈 Chart will appear once we have enough historical data</p>
          <p class="muted">Daily snapshots are being collected. Check back soon!</p>
        </div>
      )}
    </section>

    <!-- Current Positions -->
    <section class="panel">
      <h2>Current Positions</h2>
      {Object.keys(strategyData.current_positions).length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Ticker</th>
              <th>Shares</th>
              <th>Entry Price</th>
              <th>Current Price</th>
              <th>Market Value</th>
              <th>Unrealized P/L</th>
              <th>Entry Date</th>
            </tr>
          </thead>
          <tbody>
            {Object.entries(strategyData.current_positions).map(([ticker, position]) => (
              <tr>
                <td><strong>{ticker}</strong></td>
                <td>{position.shares.toFixed(2)}</td>
                <td>{formatCurrency(position.avg_entry_price)}</td>
                <td>{formatCurrency(position.current_price)}</td>
                <td>{formatCurrency(position.market_value)}</td>
                <td class={position.unrealized_pnl >= 0 ? 'positive' : 'negative'}>
                  {formatCurrency(position.unrealized_pnl)} ({formatPercent(position.unrealized_pnl_pct)})
                </td>
                <td>{position.entry_date}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="muted">No open positions</p>
      )}
    </section>

    <!-- Recent Trades -->
    <section class="panel">
      <h2>Recent Trades ({strategyTrades.length})</h2>
      {strategyTrades.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Date</th>
              <th>Side</th>
              <th>Symbol</th>
              <th>Quantity</th>
              <th>Price</th>
              <th>Notional</th>
            </tr>
          </thead>
          <tbody>
            {strategyTrades.slice(0, 20).map((trade) => (
              <tr class={trade.side}>
                <td>{formatDate(trade.timestamp)}</td>
                <td class={`side-badge ${trade.side}`}>{trade.side.toUpperCase()}</td>
                <td><strong>{trade.symbol}</strong></td>
                <td>{trade.qty}</td>
                <td>{formatCurrency(trade.price)}</td>
                <td>{formatCurrency(trade.notional)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="muted">No trades yet</p>
      )}
    </section>
  </main>
</Layout>

{hasChartData && (
  <script define:vars={{ chartData }}>
    // Import Chart.js from CDN
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js';
    script.onload = () => {
      const ctx = document.getElementById('performance-chart');
      if (!ctx) return;

      // Separate buy and sell trades
      const buyTrades = chartData.trades.filter(t => t.side === 'buy');
      const sellTrades = chartData.trades.filter(t => t.side === 'sell');

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: chartData.dates,
          datasets: [
            {
              label: 'Portfolio Value',
              data: chartData.portfolioValues,
              borderColor: '#2962ff',
              backgroundColor: 'rgba(41, 98, 255, 0.1)',
              borderWidth: 2,
              pointRadius: 2,
              pointHoverRadius: 5,
              fill: true
            },
            {
              label: 'Buy',
              data: buyTrades.map(t => ({ x: t.dateIndex, y: t.value })),
              type: 'scatter',
              backgroundColor: '#28a745',
              borderColor: '#28a745',
              pointRadius: 8,
              pointStyle: 'triangle',
              pointHoverRadius: 10
            },
            {
              label: 'Sell',
              data: sellTrades.map(t => ({ x: t.dateIndex, y: t.value })),
              type: 'scatter',
              backgroundColor: '#dc3545',
              borderColor: '#dc3545',
              pointRadius: 8,
              pointStyle: 'rectRot',
              pointHoverRadius: 10
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: {
            mode: 'index',
            intersect: false
          },
          plugins: {
            legend: {
              display: true,
              labels: {
                color: '#f8f9fa',
                usePointStyle: true
              }
            },
            tooltip: {
              backgroundColor: 'rgba(0, 0, 0, 0.8)',
              titleColor: '#f8f9fa',
              bodyColor: '#f8f9fa',
              borderColor: '#2a2e39',
              borderWidth: 1,
              callbacks: {
                label: function(context) {
                  let label = context.dataset.label || '';
                  if (label) {
                    label += ': ';
                  }
                  if (context.parsed.y !== null) {
                    label += '$' + context.parsed.y.toFixed(2);
                  }

                  // Add trade details for buy/sell points
                  const trade = chartData.trades.find(t =>
                    t.dateIndex === context.parsed.x &&
                    ((context.dataset.label === 'Buy' && t.side === 'buy') ||
                     (context.dataset.label === 'Sell' && t.side === 'sell'))
                  );

                  if (trade) {
                    return [
                      `${trade.side.toUpperCase()}: ${trade.symbol}`,
                      `Qty: ${trade.qty}`,
                      `Price: $${trade.price.toFixed(2)}`
                    ];
                  }

                  return label;
                }
              }
            }
          },
          scales: {
            x: {
              grid: {
                color: 'rgba(255, 255, 255, 0.1)'
              },
              ticks: {
                color: '#8f949e',
                maxRotation: 45,
                minRotation: 45
              }
            },
            y: {
              grid: {
                color: 'rgba(255, 255, 255, 0.1)'
              },
              ticks: {
                color: '#8f949e',
                callback: function(value) {
                  return '$' + value.toFixed(0);
                }
              }
            }
          }
        }
      });
    };
    document.head.appendChild(script);
  </script>
)}

<style>
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    color: #f8f9fa;
  }

  nav {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  nav a {
    color: #c4d4ff;
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }

  header {
    margin-bottom: 2rem;
  }

  h1 {
    margin: 0;
    font-size: 2.2rem;
  }

  h2 {
    margin-top: 0;
    font-size: 1.3rem;
  }

  .subtitle {
    color: #d1d4dc;
    margin-top: 0.5rem;
    font-size: 1.1rem;
  }

  .muted {
    color: #8f949e;
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .panel {
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .metrics-panel {
    background: linear-gradient(135deg, #1a1e2e 0%, #131722 100%);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .metric-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 8px;
    border: 1px solid #2a2e39;
  }

  .metric-card .label {
    color: #8f949e;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .metric-card .value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #f8f9fa;
  }

  .metric-card .value.positive {
    color: #28a745;
  }

  .metric-card .value.negative {
    color: #dc3545;
  }

  .metric-card .subvalue {
    color: #8f949e;
    font-size: 0.85rem;
  }

  .chart-container {
    height: 400px;
    margin-top: 1rem;
    background: #0d111b;
    border-radius: 8px;
    padding: 1rem;
  }

  .no-data {
    text-align: center;
    padding: 3rem 1rem;
    background: #0d111b;
    border-radius: 8px;
    margin-top: 1rem;
  }

  .no-data p {
    font-size: 1.1rem;
    margin: 0.5rem 0;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    background: #0d111b;
    border-radius: 8px;
    overflow: hidden;
    margin-top: 1rem;
  }

  thead {
    background: rgba(255, 255, 255, 0.05);
  }

  th {
    padding: 0.75rem 1rem;
    text-align: left;
    color: #d1d4dc;
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  td {
    padding: 0.75rem 1rem;
    border-top: 1px solid #2a2e39;
    color: #f8f9fa;
  }

  tr.buy {
    background: rgba(40, 167, 69, 0.05);
  }

  tr.sell {
    background: rgba(220, 53, 69, 0.05);
  }

  .side-badge {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .side-badge.buy {
    background: rgba(40, 167, 69, 0.3);
    color: #28a745;
  }

  .side-badge.sell {
    background: rgba(220, 53, 69, 0.3);
    color: #dc3545;
  }

  .positive {
    color: #28a745;
  }

  .negative {
    color: #dc3545;
  }

  @media (max-width: 768px) {
    main {
      padding: 1rem;
    }

    h1 {
      font-size: 1.75rem;
    }

    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .chart-container {
      height: 300px;
    }

    table {
      font-size: 0.85rem;
    }

    th, td {
      padding: 0.5rem;
    }
  }
</style>
