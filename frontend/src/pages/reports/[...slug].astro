---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const base = import.meta.env.BASE_URL;
---

<Layout title={entry.data.title}>
  <main>
    <a href={base}>← Back to Dashboard</a>
    <header>
        <h1>{entry.data.title}</h1>
        <p class="date">{entry.data.date}</p>
    </header>
    <article>
        <Content />
    </article>
  </main>
</Layout>

<style>
  main {
    max-width: 850px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    line-height: 1.7;
    color: #d1d4dc;
  }
  a {
      text-decoration: none;
      color: #8f949e;
      font-size: 0.9rem;
      font-weight: 500;
  }
  a:hover { color: #fff; }
  header {
      margin: 2rem 0 3rem;
      border-bottom: 1px solid #2a2e39;
      padding-bottom: 1.5rem;
  }
  h1 {
      margin: 0;
      font-size: 3rem;
      color: #fff;
      font-weight: 800;
      letter-spacing: -0.02em;
  }
  .date {
      color: #8f949e;
      margin-top: 0.5rem;
  }
  article {
      font-size: 1.15rem;
  }
  article :global(h2) {
      margin-top: 3rem;
      color: #fff;
      font-size: 1.75rem;
      border-bottom: 1px solid #2a2e39;
      padding-bottom: 0.5rem;
  }
  article :global(h3) {
      margin-top: 2rem;
      color: #fff;
  }
  article :global(p) {
      margin-bottom: 1.5rem;
  }
  article :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 2.5rem 0;
      background: #131722;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid #2a2e39;
  }
  article :global(th), article :global(td) {
      border: 1px solid #2a2e39;
      padding: 1rem;
      text-align: left;
  }
  article :global(th) {
      background: #1c212d;
      color: #8f949e;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
  }
  article :global(strong) {
      color: #fff;
  }
</style>
