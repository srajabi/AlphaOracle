---
import Layout from '../../layouts/Layout.astro';
import StockChart from '../../components/StockChart.tsx';
import fs from 'node:fs/promises';
import path from 'node:path';
import { getConsensus, getStatusClass, getStatusLabel, getTechnicalSignals } from '../../lib/technicals';

export async function getStaticPaths() {
  const watchlistPath = path.resolve('../watchlist.csv');
  const fileContent = await fs.readFile(watchlistPath, 'utf-8');
  const lines = fileContent.trim().split('\n');
  const records = lines.slice(1).map(line => {
    const values = line.split(',');
    return { Ticker: values[0], Sector: values[1], Notes: values[2] };
  });
  return records.map((record) => ({
    params: { ticker: record.Ticker },
    props: { sector: record.Sector, notes: record.Notes },
  }));
}

const { ticker } = Astro.params;
const { sector, notes } = Astro.props;

// Load historical data from the new public/data location
const historyPath = path.resolve(`./public/data/history/${ticker}.json`);
let historyData = [];
try {
  historyData = JSON.parse(await fs.readFile(historyPath, 'utf-8'));
} catch (e) {
  console.error(`Error loading history for ${ticker} at ${historyPath}:`, e);
}

let contextData = { data: {} };
try {
  contextData = JSON.parse(await fs.readFile(path.resolve('./public/data/market_context.json'), 'utf-8'));
} catch (e) {
  console.error('Error loading market context on ticker page:', e);
}

let tickerIndicators = null;
try {
  const indicatorsData = JSON.parse(await fs.readFile(path.resolve('./public/data/ticker_indicators.json'), 'utf-8'));
  tickerIndicators = indicatorsData.tickers?.[ticker];
} catch (e) {
  console.error('Error loading ticker indicators:', e);
}

const stockData = contextData.data?.[ticker] || {};
const signals = getTechnicalSignals(ticker, stockData, historyData);
const consensus = getConsensus(signals);
const latest = historyData[historyData.length - 1] || {};
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<Layout title={`${ticker} - AlphaOracle Analysis`}>
  <main>
    <nav>
      <a href={base}>← Daily Analysis</a>
      <a href={`${base}tickers/`}>Ticker Dashboard</a>
    </nav>

    <header class="ticker-header">
      <div class="title-group">
        <h1>{ticker}</h1>
        <span class="sector-badge">{sector}</span>
      </div>
      <div class="price-hero">
        <span class="label">Latest Price</span>
        <span class="value">${latest.close?.toFixed(2)}</span>
        <span class={`detail-consensus ${getStatusClass(consensus.status)}`}>
          {getStatusLabel(consensus.status)}: {consensus.buyCount} buy / {consensus.sellCount} sell / {consensus.holdCount} hold
        </span>
      </div>
    </header>

    <div class="dashboard-grid">
      <section class="main-chart stack">
        <div class="chart-container">
          <StockChart client:load data={historyData} />
        </div>
        <div class="chart-legend">
          <span class="legend-item"><i class="blue"></i> SMA 20</span>
          <span class="legend-item"><i class="orange"></i> SMA 50</span>
          <span class="legend-item"><i class="red"></i> SMA 200</span>
        </div>
        <div class="chart-stats">
          <div class="chart-stat">
            <span>Price vs 20 SMA</span>
            <strong>{stockData.close && stockData.sma_20 ? `${(((stockData.close - stockData.sma_20) / stockData.sma_20) * 100).toFixed(1)}%` : 'N/A'}</strong>
          </div>
          <div class="chart-stat">
            <span>Price vs 50 SMA</span>
            <strong>{stockData.close && stockData.sma_50 ? `${(((stockData.close - stockData.sma_50) / stockData.sma_50) * 100).toFixed(1)}%` : 'N/A'}</strong>
          </div>
          <div class="chart-stat">
            <span>Price vs 200 SMA</span>
            <strong>{stockData.close && stockData.sma_200 ? `${(((stockData.close - stockData.sma_200) / stockData.sma_200) * 100).toFixed(1)}%` : 'N/A'}</strong>
          </div>
          <div class="chart-stat">
            <span>RSI / MACD</span>
            <strong>{stockData.rsi_14?.toFixed(1) ?? 'N/A'} / {stockData.macd?.toFixed(2) ?? 'N/A'}</strong>
          </div>
        </div>
      </section>

      <aside class="sidebar">
        {tickerIndicators && (
          <div class="info-card indicators">
            <h3>Technical Indicators</h3>
            <div class="indicator-item">
              <span class="indicator-label">Trend Strength</span>
              <span class={`indicator-value ${tickerIndicators.trend_strength?.signal?.replace(/_/g, '-')}`}>
                {tickerIndicators.trend_strength?.signal?.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) || 'N/A'}
              </span>
              <p class="indicator-explain">{tickerIndicators.trend_strength?.interpretation || ''}</p>
            </div>
            <div class="indicator-item">
              <span class="indicator-label">Price Momentum</span>
              <span class={`indicator-value ${tickerIndicators.price_momentum?.signal?.replace(/_/g, '-')}`}>
                {tickerIndicators.price_momentum?.signal?.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) || 'N/A'}
              </span>
              {tickerIndicators.price_momentum?.periods && (
                <p class="indicator-explain">
                  5d: {tickerIndicators.price_momentum.periods['5d'] ? `${tickerIndicators.price_momentum.periods['5d'].toFixed(1)}%` : 'N/A'} |
                  20d: {tickerIndicators.price_momentum.periods['20d'] ? `${tickerIndicators.price_momentum.periods['20d'].toFixed(1)}%` : 'N/A'}
                </p>
              )}
            </div>
            <div class="indicator-item">
              <span class="indicator-label">Relative Strength vs SPY</span>
              <span class={`indicator-value ${tickerIndicators.relative_strength?.signal?.replace(/_/g, '-')}`}>
                {tickerIndicators.relative_strength?.signal?.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) || 'N/A'}
              </span>
              {tickerIndicators.relative_strength?.periods && tickerIndicators.relative_strength.periods['60d'] && (
                <p class="indicator-explain">
                  60d: {tickerIndicators.relative_strength.periods['60d'].outperformance > 0 ? '+' : ''}{tickerIndicators.relative_strength.periods['60d'].outperformance.toFixed(1)}% vs SPY
                </p>
              )}
            </div>
            <div class="indicator-item">
              <span class="indicator-label">Volume Profile</span>
              <span class={`indicator-value ${tickerIndicators.volume_profile?.signal?.replace(/_/g, '-')}`}>
                {tickerIndicators.volume_profile?.signal?.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) || 'N/A'}
              </span>
              <p class="indicator-explain">{tickerIndicators.volume_profile?.interpretation || ''}</p>
            </div>
            <div class="indicator-item">
              <span class="indicator-label">Support/Resistance</span>
              <span class={`indicator-value ${tickerIndicators.support_resistance?.signal?.replace(/_/g, '-')}`}>
                {tickerIndicators.support_resistance?.signal?.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) || 'N/A'}
              </span>
              <p class="indicator-explain">{tickerIndicators.support_resistance?.interpretation || ''}</p>
            </div>
          </div>
        )}

        <div class="info-card">
          <h3>Thesis & Notes</h3>
          <p>{notes}</p>
        </div>

        <div class="info-card stats">
          <h3>Key Metrics</h3>
          <div class="stat-row">
            <span>20 SMA</span>
            <span class="val">${latest.sma20?.toFixed(2)}</span>
          </div>
          <div class="stat-row">
            <span>50 SMA</span>
            <span class="val">${latest.sma50?.toFixed(2)}</span>
          </div>
          <div class="stat-row">
            <span>200 SMA</span>
            <span class="val">${latest.sma200?.toFixed(2)}</span>
          </div>
          <div class="stat-row">
            <span>RSI 14</span>
            <span class="val">{stockData.rsi_14?.toFixed(1) ?? 'N/A'}</span>
          </div>
          <div class="stat-row">
            <span>MACD</span>
            <span class="val">{stockData.macd?.toFixed(2) ?? 'N/A'}</span>
          </div>
          <div class="stat-row">
            <span>MACD Signal</span>
            <span class="val">{stockData.macd_signal?.toFixed(2) ?? 'N/A'}</span>
          </div>
          <div class="stat-row">
            <span>Bollinger Low</span>
            <span class="val">${stockData.bb_lower?.toFixed(2) ?? 'N/A'}</span>
          </div>
          <div class="stat-row">
            <span>Bollinger High</span>
            <span class="val">${stockData.bb_upper?.toFixed(2) ?? 'N/A'}</span>
          </div>
          <div class="stat-row">
            <span>Volume</span>
            <span class="val">{(latest.volume / 1000000).toFixed(1)}M</span>
          </div>
        </div>
      </aside>
    </div>

    <section class="why-panel">
      <div class="why-header">
        <h3>Why This Rating</h3>
        <p>Each technical signal contributes a buy, sell, or hold call.</p>
      </div>
      <div class="signal-list">
        {signals.map((signal) => (
          <article class="signal-card">
            <div class="signal-card-top">
              <div>
                <h4>{signal.label}</h4>
                <p>{signal.value}</p>
              </div>
              <span class={`signal-badge ${getStatusClass(signal.status)}`}>{getStatusLabel(signal.status)}</span>
            </div>
            <p class="signal-reason">{signal.reason}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: #f8f9fa;
    background: #0b0e14;
    min-height: 100vh;
  }
  nav { margin-bottom: 1.5rem; display: flex; gap: 1rem; }
  nav a { color: #8f949e; text-decoration: none; font-size: 0.9rem; font-weight: 500; }
  nav a:hover { color: #fff; }

  .ticker-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #2a2e39;
  }
  h1 { font-size: 3rem; margin: 0; font-weight: 800; line-height: 1; }
  .sector-badge { 
    background: #2a2e39; 
    padding: 0.4rem 0.8rem; 
    border-radius: 6px; 
    font-size: 0.75rem; 
    text-transform: uppercase; 
    letter-spacing: 0.05em;
    color: #d1d4dc;
    margin-top: 0.5rem;
    display: inline-block;
  }
  .price-hero { text-align: right; }
  .price-hero .label { display: block; font-size: 0.8rem; color: #8f949e; text-transform: uppercase; margin-bottom: 0.25rem; }
  .price-hero .value { font-size: 2.5rem; font-weight: 700; color: #fff; }
  .detail-consensus {
    display: inline-block;
    margin-top: 0.65rem;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid transparent;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 1.5rem;
  }

  .main-chart {
    background: #131722;
    border-radius: 12px;
    border: 1px solid #2a2e39;
    padding: 1rem;
  }
  .stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .chart-container { border-radius: 8px; overflow: hidden; }
  
  .chart-legend {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    padding: 0 0.5rem;
  }
  .legend-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: #d1d4dc; }
  .legend-item i { width: 12px; height: 3px; border-radius: 2px; }
  .legend-item .blue { background: #2962FF; }
  .legend-item .orange { background: #FF9800; }
  .legend-item .red { background: #F44336; }
  .chart-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }
  .chart-stat {
    background: #1a1f2b;
    border: 1px solid #2a2e39;
    border-radius: 10px;
    padding: 0.8rem;
  }
  .chart-stat span {
    display: block;
    color: #8f949e;
    font-size: 0.76rem;
    margin-bottom: 0.25rem;
  }
  .chart-stat strong {
    color: #fff;
    font-size: 0.95rem;
  }
  .why-panel {
    margin-top: 1.5rem;
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 12px;
    padding: 1rem;
  }
  .why-header h3 {
    margin: 0;
    font-size: 1rem;
    color: #fff;
  }
  .why-header p {
    margin: 0.35rem 0 0;
    color: #8f949e;
    font-size: 0.88rem;
  }
  .signal-list {
    margin-top: 0.9rem;
    display: grid;
    gap: 0.8rem;
  }
  .signal-card {
    background: #1a1f2b;
    border: 1px solid #2a2e39;
    border-radius: 12px;
    padding: 0.9rem;
  }
  .signal-card-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }
  .signal-card h4 {
    margin: 0;
    font-size: 0.95rem;
  }
  .signal-card-top p {
    margin: 0.3rem 0 0;
    color: #8f949e;
    font-size: 0.82rem;
  }
  .signal-badge {
    border-radius: 999px;
    padding: 0.3rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .signal-reason {
    margin: 0.75rem 0 0;
    color: #d1d4dc;
    line-height: 1.55;
    font-size: 0.92rem;
  }

  .sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
  .info-card {
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 12px;
    padding: 1.5rem;
  }
  .info-card h3 { margin-top: 0; font-size: 1rem; color: #8f949e; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem; }
  .info-card p { margin: 0; line-height: 1.6; color: #d1d4dc; }
  
  .stat-row {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid #2a2e39;
  }
  .stat-row:last-child { border-bottom: none; }
  .stat-row span { color: #8f949e; font-size: 0.9rem; }
  .stat-row .val { color: #fff; font-weight: 600; }
  .is-buy { color: #26a69a; border-color: rgba(38, 166, 154, 0.4); background: rgba(38, 166, 154, 0.12); }
  .is-sell { color: #ef5350; border-color: rgba(239, 83, 80, 0.4); background: rgba(239, 83, 80, 0.12); }
  .is-hold { color: #ffc107; border-color: rgba(255, 193, 7, 0.4); background: rgba(255, 193, 7, 0.12); }
  .is-na { color: #8f949e; border-color: rgba(143, 148, 158, 0.3); background: rgba(143, 148, 158, 0.08); }

  /* Ticker Indicators */
  .indicator-item {
    padding: 0.9rem 0;
    border-bottom: 1px solid #2a2e39;
  }
  .indicator-item:last-child {
    border-bottom: none;
  }
  .indicator-label {
    display: block;
    color: #8f949e;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.4rem;
  }
  .indicator-value {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.05);
  }
  .indicator-value.strong-uptrend,
  .indicator-value.uptrend {
    color: #26a69a;
    background: rgba(38, 166, 154, 0.12);
  }
  .indicator-value.strong-downtrend,
  .indicator-value.downtrend {
    color: #ef5350;
    background: rgba(239, 83, 80, 0.12);
  }
  .indicator-value.choppy,
  .indicator-value.neutral {
    color: #ffc107;
    background: rgba(255, 193, 7, 0.12);
  }
  .indicator-value.strong-positive,
  .indicator-value.positive,
  .indicator-value.slightly-positive {
    color: #26a69a;
    background: rgba(38, 166, 154, 0.12);
  }
  .indicator-value.strong-negative,
  .indicator-value.negative,
  .indicator-value.slightly-negative {
    color: #ef5350;
    background: rgba(239, 83, 80, 0.12);
  }
  .indicator-value.strong-outperformance,
  .indicator-value.outperformance {
    color: #26a69a;
    background: rgba(38, 166, 154, 0.12);
  }
  .indicator-value.strong-underperformance,
  .indicator-value.underperformance {
    color: #ef5350;
    background: rgba(239, 83, 80, 0.12);
  }
  .indicator-value.bullish-volume,
  .indicator-value.volume-confirming-uptrend {
    color: #26a69a;
    background: rgba(38, 166, 154, 0.12);
  }
  .indicator-value.bearish-volume,
  .indicator-value.volume-confirming-downtrend {
    color: #ef5350;
    background: rgba(239, 83, 80, 0.12);
  }
  .indicator-value.weak-uptrend {
    color: #ffc107;
    background: rgba(255, 193, 7, 0.12);
  }
  .indicator-value.at-resistance {
    color: #ef5350;
    background: rgba(239, 83, 80, 0.12);
  }
  .indicator-value.at-support {
    color: #26a69a;
    background: rgba(38, 166, 154, 0.12);
  }
  .indicator-value.closer-to-resistance,
  .indicator-value.closer-to-support {
    color: #8f949e;
    background: rgba(143, 148, 158, 0.12);
  }
  .indicator-value.no-data {
    color: #8f949e;
    background: rgba(143, 148, 158, 0.08);
  }
  .indicator-explain {
    margin: 0.4rem 0 0;
    font-size: 0.8rem;
    color: #d1d4dc;
    line-height: 1.4;
  }

  @media (max-width: 1100px) {
    .dashboard-grid { grid-template-columns: 1fr; }
    .chart-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 720px) {
    .ticker-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .price-hero { text-align: left; }
    .chart-stats { grid-template-columns: 1fr; }
    .signal-card-top { flex-direction: column; }
  }
</style>
