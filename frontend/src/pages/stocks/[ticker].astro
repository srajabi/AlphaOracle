---
import Layout from '../../layouts/Layout.astro';
import StockChart from '../../components/StockChart.tsx';
import fs from 'node:fs/promises';
import path from 'node:path';

export async function getStaticPaths() {
  const watchlistPath = path.resolve('../watchlist.csv');
  const fileContent = await fs.readFile(watchlistPath, 'utf-8');
  const lines = fileContent.trim().split('\n');
  const records = lines.slice(1).map(line => {
    const values = line.split(',');
    return { Ticker: values[0], Sector: values[1], Notes: values[2] };
  });
  return records.map((record) => ({
    params: { ticker: record.Ticker },
    props: { sector: record.Sector, notes: record.Notes },
  }));
}

const { ticker } = Astro.params;
const { sector, notes } = Astro.props;

// Load historical data from the new public/data location
const historyPath = path.resolve(`./public/data/history/${ticker}.json`);
let historyData = [];
try {
  historyData = JSON.parse(await fs.readFile(historyPath, 'utf-8'));
} catch (e) {
  console.error(`Error loading history for ${ticker} at ${historyPath}:`, e);
}

const latest = historyData[historyData.length - 1] || {};
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<Layout title={`${ticker} - AlphaOracle Analysis`}>
  <main>
    <nav>
      <a href={base}>← Dashboard</a>
    </nav>

    <header class="ticker-header">
      <div class="title-group">
        <h1>{ticker}</h1>
        <span class="sector-badge">{sector}</span>
      </div>
      <div class="price-hero">
        <span class="label">Latest Price</span>
        <span class="value">${latest.close?.toFixed(2)}</span>
      </div>
    </header>

    <div class="dashboard-grid">
      <section class="main-chart">
        <div class="chart-container">
          <StockChart client:load data={historyData} />
        </div>
        <div class="chart-legend">
          <span class="legend-item"><i class="blue"></i> SMA 20</span>
          <span class="legend-item"><i class="orange"></i> SMA 50</span>
          <span class="legend-item"><i class="red"></i> SMA 200</span>
        </div>
      </section>

      <aside class="sidebar">
        <div class="info-card">
          <h3>Thesis & Notes</h3>
          <p>{notes}</p>
        </div>

        <div class="info-card stats">
          <h3>Key Metrics</h3>
          <div class="stat-row">
            <span>20 SMA</span>
            <span class="val">${latest.sma20?.toFixed(2)}</span>
          </div>
          <div class="stat-row">
            <span>50 SMA</span>
            <span class="val">${latest.sma50?.toFixed(2)}</span>
          </div>
          <div class="stat-row">
            <span>200 SMA</span>
            <span class="val">${latest.sma200?.toFixed(2)}</span>
          </div>
          <div class="stat-row">
            <span>Volume</span>
            <span class="val">{(latest.volume / 1000000).toFixed(1)}M</span>
          </div>
        </div>
      </aside>
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: #f8f9fa;
    background: #0b0e14;
    min-height: 100vh;
  }
  nav { margin-bottom: 1.5rem; }
  nav a { color: #8f949e; text-decoration: none; font-size: 0.9rem; font-weight: 500; }
  nav a:hover { color: #fff; }

  .ticker-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #2a2e39;
  }
  h1 { font-size: 3rem; margin: 0; font-weight: 800; line-height: 1; }
  .sector-badge { 
    background: #2a2e39; 
    padding: 0.4rem 0.8rem; 
    border-radius: 6px; 
    font-size: 0.75rem; 
    text-transform: uppercase; 
    letter-spacing: 0.05em;
    color: #d1d4dc;
    margin-top: 0.5rem;
    display: inline-block;
  }
  .price-hero { text-align: right; }
  .price-hero .label { display: block; font-size: 0.8rem; color: #8f949e; text-transform: uppercase; margin-bottom: 0.25rem; }
  .price-hero .value { font-size: 2.5rem; font-weight: 700; color: #fff; }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 1.5rem;
  }

  .main-chart {
    background: #131722;
    border-radius: 12px;
    border: 1px solid #2a2e39;
    padding: 1rem;
  }
  .chart-container { border-radius: 8px; overflow: hidden; }
  
  .chart-legend {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    padding: 0 0.5rem;
  }
  .legend-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: #d1d4dc; }
  .legend-item i { width: 12px; height: 3px; border-radius: 2px; }
  .legend-item .blue { background: #2962FF; }
  .legend-item .orange { background: #FF9800; }
  .legend-item .red { background: #F44336; }

  .sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
  .info-card {
    background: #131722;
    border: 1px solid #2a2e39;
    border-radius: 12px;
    padding: 1.5rem;
  }
  .info-card h3 { margin-top: 0; font-size: 1rem; color: #8f949e; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem; }
  .info-card p { margin: 0; line-height: 1.6; color: #d1d4dc; }
  
  .stat-row {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid #2a2e39;
  }
  .stat-row:last-child { border-bottom: none; }
  .stat-row span { color: #8f949e; font-size: 0.9rem; }
  .stat-row .val { color: #fff; font-weight: 600; }
</style>
